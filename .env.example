# Copy this file to .env and fill in your key.
# Get a Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Models (override if you have access to newer ones)
GEMINI_PARSE_MODEL=gemini-2.5-flash
GEMINI_GEN_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_MAX_OUTPUT_TOKENS=32768
# Embedding output dimension for gemini-embedding-001 (768, 1536 or 3072)
EMBED_DIM=1536

# Retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=6

# Storage
DATA_DIR=data
