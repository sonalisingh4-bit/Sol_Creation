# PW proxy / Google sign-in
GOOGLE_CLIENT_ID=
APP_SESSION_DAYS=7

# Gemini models are selected by name; credentials live only in the PW proxy.
PW_PARSE_MODEL=gemini-2.5-flash
PW_GEN_MODEL=gemini-2.5-pro
PW_MAX_OUTPUT_TOKENS=32768

# Local lexical knowledge-base vectors
EMBED_DIM=1536

# Retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=6

# Storage
DATA_DIR=data

# --- Knowledge base (foundation: Class 6-10, CBSE & ICSE) -------------------
# Faculty machines: paste the share link of the prebuilt index zip (published
# by the admin with scripts/build_kb.py). It downloads automatically on start.
KB_INDEX_URL=

# Admin only: the shared Google Drive folder holding the foundation book files
# (share it as "Anyone with the link - Viewer"), used by scripts/build_kb.py.
KB_DRIVE_FOLDER=

# Admin only, optional: Google API key with the Drive API enabled. Without it
# the keyless downloader lists at most 50 files per Drive subfolder.
DRIVE_API_KEY=
